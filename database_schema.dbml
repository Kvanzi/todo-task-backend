Project todo_db {
  database_type: 'PostgreSQL'
}

// === IDENTITY MODULE ===

Table users {
  id UUID [pk] // hibernate side generation UUIDv7
  first_name VARCHAR [not null]
  last_name VARCHAR
  email VARCHAR [unique, not null]
  created_at TIMESTAMPTZ [not null, default: `now()`]
  updated_at TIMESTAMPTZ
}

Table user_roles {
  user_id UUID [not null, ref: > users.id]
  role VARCHAR [not null, note: "CHECK (role IN ('USER', 'ADMIN'))"]

  indexes {
    (user_id, role) [name: 'idx_unique_user_role', unique]
  }
}

// === TASKS MODULE ===

Table tasks {
  id UUID [pk] // hibernate side generation UUIDv7
  version BIGINT [not null, default: 0]
  name VARCHAR [not null]
  priority VARCHAR [not null, note: "CHECK (priority IN ('LOW', 'MEDIUM', 'HIGH'))"]
  state VARCHAR [not null, note: "CHECK (state IN ('TODO', 'IN_PROGRESS', 'DONE'))"]
  owner_id UUID [not null]
  created_at TIMESTAMPTZ [not null, default: `now()`]
  updated_at TIMESTAMPTZ

  indexes {
    priority [name: 'idx_task_priority']
    state [name: 'idx_task_state']
    owner_id [name: 'idx_task_owner_id']
  }
}

Table task_collaborators {
  task_id UUID [not null, ref: > tasks.id]
  user_id UUID [not null]

  indexes {
    (task_id, user_id) [name: 'idx_unique_task_collaborator', unique]
  }
}

// === AUTH MODULE ===

Table refresh_tokens {
  id UUID [pk] // jti, hibernate side generation UUIDv7
  revoked BOOLEAN [not null, default: false]
  expires_at timestamptz [not null]
  issued_at timestamptz [not null]
  user_id UUID [not null]
  created_at TIMESTAMPTZ [not null, default: `now()`]
  updated_at TIMESTAMPTZ

  indexes {
    user_id [name: "idx_jwt_token_user_id"]
  }
}
