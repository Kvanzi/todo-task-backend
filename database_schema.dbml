Project todo_db {
  database_type: 'PostgreSQL'
}

// === IDENTITY MODULE ===

Table users {
  id UUID [pk] // hibernate side generation UUIDv7
  first_name VARCHAR [not null]
  last_name VARCHAR [not null]
  email VARCHAR [unique, not null]
  password_hash VARCHAR [not null]
  last_password_changed_at TIMESTAMPTZ
  created_at TIMESTAMPTZ [not null, default: `now()`]
  updated_at TIMESTAMPTZ
}

Table user_roles {
  user_id UUID [pk, not null, ref: > users.id]
  role VARCHAR [pk, not null, note: "CHECK (role IN ('USER', 'ADMIN'))"]
}

// === TASKS MODULE ===

Table tasks {
  id UUID [pk] // hibernate side generation UUIDv7
  version BIGINT [not null, default: 0]
  name VARCHAR [not null]
  priority VARCHAR [not null, note: "CHECK (priority IN ('LOW', 'MEDIUM', 'HIGH'))"]
  priority_weight SMALLINT [not null]
  state VARCHAR [not null, note: "CHECK (state IN ('TODO', 'IN_PROGRESS', 'DONE'))"]
  owner_id UUID [not null]
  created_at TIMESTAMPTZ [not null, default: `now()`]
  updated_at TIMESTAMPTZ

  indexes {
    priority [name: 'idx_task_priority']
    state [name: 'idx_task_state']
    owner_id [name: 'idx_task_owner_id']
  }
}

Table task_collaborators {
  task_id UUID [pk, not null, ref: > tasks.id]
  user_id UUID [pk, not null]
}

// === AUTH MODULE ===

Table jwt_tokens {
  id UUID [pk] // jti, hibernate side generation UUIDv7
  revoked BOOLEAN [not null, default: false]
  expires_at TIMESTAMPTZ [not null]
  issued_at TIMESTAMPTZ [not null]
  user_id UUID [not null]
  token_type VARCHAR [not null, note: "CHECK (token_type IN ('REFRESH', 'ACCESS'))"]
  created_at TIMESTAMPTZ [not null, default: `now()`]
  updated_at TIMESTAMPTZ

  indexes {
    user_id [name: "idx_jwt_token_user_id"]
  }
}